<?xml version="1.0" encoding="utf-8"?>
<!--
  Paths exposed to the FileProvider used by camera/share/file-picker
  intents. Keep this list narrow — only paths the app actually uses.
-->
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Internal app cache (camera captures, picker copies) -->
    <cache-path
        name="cache"
        path="." />

    <!-- Internal app files directory -->
    <files-path
        name="files"
        path="." />

    <!-- External app-private cache (used by file_picker on Android) -->
    <external-cache-path
        name="external_cache"
        path="." />

    <!-- External app-private files (downloads / shares) -->
    <external-files-path
        name="external_files"
        path="." />
</paths>
