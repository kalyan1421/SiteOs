# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# Environment Variables
.env
**/.env
# Allow .env.example to be committed as a template
!.env.example
**/.env.example
# App env file loaded by flutter_dotenv (contains Supabase keys) — keep local only
assets/env
!assets/env.example

# IDE and Editor files
.claude/
.vscode/
.idea/

# IntelliJ related
*.iml
*.ipr
*.iws

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
**/build/
/coverage/
android/.kotlin/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Supabase and Firebase
.firebase/
# Firebase app config files (contain project keys) — keep local only
**/google-services.json
**/GoogleService-Info.plist

# Android release signing — NEVER commit these
android/key.properties
**/*.jks
**/*.keystore
