# SiteOS environment configuration — copy to `assets/env` and fill in real values.
# This file is a committed template; `assets/env` itself is gitignored.

# Supabase Configuration
# Get these from your Supabase project: Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Optional: Debug mode (controls Supabase debug logging)
DEBUG_MODE=false

# Optional: App environment (development | staging | production)
APP_ENV=development
